# Supabase (required for /api/words — Settings → API Keys)
# Use the Secret key (sb_secret_...) or legacy service_role JWT. Not the publishable key.
# Never expose this to the browser or commit it.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: when set, Next.js proxies /api/* to this URL instead of local Route Handlers.
# If you proxy, your remote API must implement the same routes; otherwise leave unset
# and use Supabase via the handlers in this repo.
# BACKEND_URL=

# Optional: public API base if the browser must call cross-origin (`/api` is not rewritten).
# NEXT_PUBLIC_API_URL=

NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_AUTHORIZED_EMAIL=
