# Server-only: Express API URL (used by Next.js rewrites for /api/*)
BACKEND_URL=http://localhost:5000

# Optional: set to your public API URL if the browser must call the API directly
# (e.g. cross-origin). Leave empty to use same-origin /api with rewrites.
# NEXT_PUBLIC_API_URL=https://your-api.railway.app

NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_AUTHORIZED_EMAIL=
